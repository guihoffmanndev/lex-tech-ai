# Frontend (Vite) — these MUST be safe to ship in the client bundle.
# Only the publishable/anon key may be exposed; never paste a service_role key here.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# PostHog (client-side analytics & error tracking)
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN="phc_..."
VITE_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# PostHog source map upload (build-time only — DO NOT expose to client bundle)
# Personal API key with "error tracking: write" scope: https://app.posthog.com/settings/user-api-keys
# POSTHOG_API_KEY="phx_..."
# POSTHOG_PROJECT_ID="411348"
# POSTHOG_HOST="https://us.i.posthog.com"

# ---------------------------------------------------------------------------
# Edge Function secrets (set with `supabase secrets set <NAME>=<VALUE>`).
# These are NEVER read from this file at runtime — listed here for reference.
# ---------------------------------------------------------------------------

# Auto-injected by Supabase in production. Do not commit real values.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# AI gateway
# GOOGLE_AI_API_KEY=

# Stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PLUS=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRODUCT_STARTER=prod_...
# STRIPE_PRODUCT_PLUS=prod_...
# STRIPE_PRODUCT_PRO=prod_...

# CORS allow-list (comma-separated NOT supported — single origin only).
# PRODUCTION_URL=https://app.example.com

# Shared secret protecting the sync-indices cron endpoint.
# SYNC_INDICES_SECRET=
